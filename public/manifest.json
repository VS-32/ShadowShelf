{
  "manifest_version": 3,
  "name": "ShadowShelf",
  "version": "1.0.0",
  "description": "Your Digital Mirror. Track browsing habits, save highlights, and remember what matters — all locally.",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "ShadowShelf"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "clipboardRead",
    "alarms",
    "notifications",
    "idle"
  ],
  "host_permissions": ["<all_urls>"],
  "web_accessible_resources": [
    {
      "resources": ["dashboard/index.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "options_ui": {
    "page": "dashboard/index.html",
    "open_in_tab": true
  }
}
